{
  "_comment": "Copy this file to C:\\ComicAutomation\\routing.json and edit to match your setup.",

  "destinations": {
    "comics": "\\\\your-server\\media\\comics\\Comix",
    "manga":  "\\\\your-server\\media\\comics\\Manga"
  },

  "default": "comics",

  "rules": [
    { "_comment": "--- Manga / manhwa sources ---" },
    { "match": "source", "pattern": "MangaDex (EN)",         "dest": "manga" },
    { "match": "source", "pattern": "Atsumaru*",              "dest": "manga" },
    { "match": "source", "pattern": "Webtoons*",             "dest": "manga" },
    { "match": "source", "pattern": "MangaFire (EN)",        "dest": "manga" },
    { "match": "source", "pattern": "ManyToon (EN)",         "dest": "manga" },

    { "_comment": "--- Comics / western sources go to default (comics) ---" },

    { "_comment": "--- Title-based overrides (match on comic directory name) ---" },
    { "match": "title",  "pattern": "Batman*",               "dest": "comics" }
  ]
}
